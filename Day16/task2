import numpy as np
import pandas as pd

np.random.seed(42)
data = np.random.normal(50, 10, 100)   
data = np.append(data, [150, -20])    

df = pd.DataFrame({"Values": data})


mu = df["Values"].mean()
sigma = df["Values"].std()

print("Mean (μ):", mu)
print("Standard Deviation (σ):", sigma)


df["z_score"] = (df["Values"] - mu) / sigma


outliers = df[np.abs(df["z_score"]) > 3]

print("\nOutliers (|Z| > 3):")
print(outliers)
